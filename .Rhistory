# ==============================================================================
# 8. Statistiques descriptives
# ==============================================================================
# install.packages(c("psych", "ggplot2", "tidyr", "ggcorrplot", "plm", "lmtest", "car", "scales"))
library(psych)
library(ggplot2)
library(tidyr)
variables_quanti <- c(
"PIB_croissance_reel_pct", "PIB_hab_croissance_pct", "PIB_hab_USD_constant2015",
"Rente_ress_naturelles_pctPIB", "IDE_net_entrant_pctPIB", "Ouverture_commerciale_pctPIB",
"Inflation_IPC_pct", "Depenses_publiques_pctPIB", "FBCF_pctPIB"
)
# 8.1 Statistiques descriptives globales (N, moyenne, ecart-type, min, max, etc.)
stats_globales <- describe(panel_final[, variables_quanti])
print(stats_globales)
write.csv(stats_globales, "stats_descriptives_globales.csv")
# 8.2 Statistiques par statut ITIE (0 = hors ITIE, 1 = ITIE actif)
stats_par_groupe <- describeBy(panel_final[, variables_quanti],
group = panel_final$ITIE_dummy, mat = TRUE)
print(stats_par_groupe)
write.csv(stats_par_groupe, "stats_descriptives_par_groupe_ITIE.csv")
# 8.3 Statistiques par pays (moyennes 1995-2024)
stats_par_pays <- panel_final %>%
group_by(Code_ISO3, Pays) %>%
summarise(across(all_of(variables_quanti), ~round(mean(.x, na.rm = TRUE), 2)),
.groups = "drop")
print(stats_par_pays)
write.csv(stats_par_pays, "stats_descriptives_par_pays.csv", row.names = FALSE)
# 8.4 Tableau croise : nombre d'annees-pays par statut ITIE
table_itie_pays <- table(panel_final$Pays, panel_final$ITIE_dummy)
print(table_itie_pays)
# ==============================================================================
# 9. Analyse univariee : distributions
# ==============================================================================
panel_long <- panel_final %>%
select(Code_ISO3, Pays, Annee, ITIE_dummy, all_of(variables_quanti)) %>%
pivot_longer(cols = all_of(variables_quanti), names_to = "variable", values_to = "valeur")
# 9.1 Histogrammes de toutes les variables (une facette par variable)
g_hist <- ggplot(panel_long, aes(x = valeur)) +
geom_histogram(bins = 25, fill = "#1F4E78", color = "white", na.rm = TRUE) +
facet_wrap(~variable, scales = "free", ncol = 3) +
theme_minimal() +
labs(title = "Distribution des variables - panel ITIE-UEMOA (1995-2024)",
x = NULL, y = "Frequence")
print(g_hist)
# 9.2 Boites a moustaches de toutes les variables (detection des valeurs atypiques)
g_box_all <- ggplot(panel_long, aes(x = "", y = valeur)) +
geom_boxplot(fill = "#D9E1F2", outlier.color = "firebrick", na.rm = TRUE) +
facet_wrap(~variable, scales = "free", ncol = 3) +
theme_minimal() +
theme(axis.text.x = element_blank(), axis.ticks.x = element_blank()) +
labs(title = "Boites a moustaches par variable", x = NULL, y = NULL)
print(g_box_all)
# 9.3 Densite de la croissance du PIB reel selon le statut ITIE
g_dens_itie <- ggplot(panel_final, aes(x = PIB_croissance_reel_pct, fill = factor(ITIE_dummy))) +
geom_density(alpha = 0.45, na.rm = TRUE) +
scale_fill_manual(values = c("0" = "grey60", "1" = "#1F4E78"),
labels = c("Hors ITIE", "ITIE actif"), name = "Statut") +
theme_minimal() +
labs(title = "Densite de la croissance du PIB reel selon le statut ITIE",
x = "Croissance du PIB reel (%)", y = "Densite")
print(g_dens_itie)
# 9.4 Evolution de la part de pays-annees "ITIE actif" dans le panel
g_part_itie <- panel_final %>%
group_by(Annee) %>%
summarise(part_itie = mean(ITIE_dummy, na.rm = TRUE)) %>%
ggplot(aes(x = Annee, y = part_itie)) +
geom_line(color = "#1F4E78", linewidth = 1) +
geom_point(color = "#1F4E78") +
scale_y_continuous(labels = scales::percent) +
theme_minimal() +
labs(title = "Part des pays-annees sous regime ITIE actif (1995-2024)",
x = NULL, y = "Part de l'echantillon")
print(g_part_itie)
# ==============================================================================
# 10. Analyse bivariee
# ==============================================================================
library(ggcorrplot)
# 10.1 Matrice de correlation (Pearson) entre variables quantitatives
mat_corr <- cor(panel_final[, variables_quanti], use = "pairwise.complete.obs")
g_corr <- ggcorrplot(mat_corr, type = "lower", lab = TRUE, lab_size = 2.8,
colors = c("#B2182B", "white", "#1F4E78"), tl.cex = 8) +
labs(title = "Matrice de correlation - panel ITIE-UEMOA")
print(g_corr)
# 10.2 Nuages de points : croissance du PIB vs chaque variable de controle,
#      colores par statut ITIE, avec droite de regression lineaire
for (var in setdiff(variables_quanti, "PIB_croissance_reel_pct")) {
g <- ggplot(panel_final, aes(x = .data[[var]], y = PIB_croissance_reel_pct,
color = factor(ITIE_dummy))) +
geom_point(alpha = 0.6, na.rm = TRUE) +
geom_smooth(method = "lm", se = FALSE, na.rm = TRUE) +
scale_color_manual(values = c("0" = "grey60", "1" = "#1F4E78"),
labels = c("Hors ITIE", "ITIE actif"), name = "Statut") +
theme_minimal() +
labs(title = paste("Croissance du PIB reel vs", var),
x = var, y = "Croissance du PIB reel (%)")
print(g)
}
# 10.3 Boites a moustaches : croissance du PIB selon le statut ITIE
g_box_itie <- ggplot(panel_final, aes(x = factor(ITIE_dummy), y = PIB_croissance_reel_pct,
fill = factor(ITIE_dummy))) +
geom_boxplot(na.rm = TRUE) +
geom_jitter(width = 0.15, alpha = 0.3, na.rm = TRUE) +
scale_x_discrete(labels = c("Hors ITIE", "ITIE actif")) +
scale_fill_manual(values = c("0" = "grey60", "1" = "#1F4E78"), guide = "none") +
theme_minimal() +
labs(title = "Croissance du PIB reel selon le statut ITIE",
x = NULL, y = "Croissance du PIB reel (%)")
print(g_box_itie)
# 10.4 Boites a moustaches : croissance du PIB par pays
g_box_pays <- ggplot(panel_final, aes(x = Pays, y = PIB_croissance_reel_pct, fill = Pays)) +
geom_boxplot(na.rm = TRUE) +
theme_minimal() +
theme(legend.position = "none", axis.text.x = element_text(angle = 45, hjust = 1)) +
labs(title = "Croissance du PIB reel par pays (1995-2024)", x = NULL, y = "Croissance du PIB reel (%)")
print(g_box_pays)
# 10.5 Score ITIE vs controle de la corruption (nuage de points + regression)
g_score_corr <- ggplot(panel_final, aes(x = ITIE_score_ordinal, y = Controle_corruption_WGI)) +
geom_jitter(width = 0.1, alpha = 0.5, color = "#1F4E78", na.rm = TRUE) +
geom_smooth(method = "lm", se = TRUE, color = "firebrick", na.rm = TRUE) +
theme_minimal() +
labs(title = "Score ITIE vs indicateur de controle de la corruption",
x = "Score ITIE (0=non-membre, 1=candidat, 2=conforme/validation)",
y = "Controle de la corruption (WGI)")
print(g_score_corr)
