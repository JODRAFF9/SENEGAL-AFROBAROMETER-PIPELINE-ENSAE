# install.packages(c("psych", "ggplot2", "tidyr", "ggcorrplot", "plm", "lmtest", "car", "scales"))
library(psych)
library(ggplot2)
library(tidyr)
variables_quanti <- c(
"PIB_croissance_reel_pct", "PIB_hab_croissance_pct", "PIB_hab_USD_constant2015",
"Rente_ress_naturelles_pctPIB", "IDE_net_entrant_pctPIB", "Ouverture_commerciale_pctPIB",
"Inflation_IPC_pct", "Depenses_publiques_pctPIB", "FBCF_pctPIB",
"Controle_corruption_WGI", "Etat_droit_WGI", "Efficacite_gouv_WGI"
)
# 8.1 Statistiques descriptives globales (N, moyenne, ecart-type, min, max, etc.)
stats_globales <- describe(panel_final[, variables_quanti])
# ==============================================================================
# Recuperation des donnees macroeconomiques (WDI) et de gouvernance (WGI)
# Banque mondiale - 8 pays UEMOA, panel 1995-2024
#
# Variables recuperees (noms alignes sur l'onglet "Panel_Data" du fichier
# panel_ITIE_UEMOA.xlsx) :
#   - PIB_croissance_reel_pct      <- NY.GDP.MKTP.KD.ZG
#   - PIB_hab_croissance_pct       <- NY.GDP.PCAP.KD.ZG
#   - PIB_hab_USD_constant2015     <- NY.GDP.PCAP.KD
#   - Rente_ress_naturelles_pctPIB <- NY.GDP.TOTL.RT.ZS
#   - IDE_net_entrant_pctPIB       <- BX.KLT.DINV.WD.GD.ZS
#   - Ouverture_commerciale_pctPIB <- NE.TRD.GNFS.ZS
#   - Inflation_IPC_pct            <- FP.CPI.TOTL.ZG
#   - Depenses_publiques_pctPIB    <- NE.CON.GOVT.ZS
#   - FBCF_pctPIB                  <- NE.GDI.FTOT.ZS
#   - Controle_corruption_WGI      <- CC.EST  (1996,1998,2000, puis annuel depuis 2002)
#   - Etat_droit_WGI               <- RL.EST  (idem)
#   - Efficacite_gouv_WGI          <- GE.EST  (idem)
# ==============================================================================
# install.packages(c("WDI", "dplyr", "openxlsx"))  # a executer une seule fois
library(WDI)
library(dplyr)
library(openxlsx)
# --- 1. Parametres -----------------------------------------------------------
# Codes ISO-2 attendus par le package WDI
pays_iso2 <- c(
"BJ",  # Benin
"BF",  # Burkina Faso
"CI",  # Cote d'Ivoire
"GW",  # Guinee-Bissau
"ML",  # Mali
"NE",  # Niger
"SN",  # Senegal
"TG"   # Togo
)
indicateurs <- c(
PIB_croissance_reel_pct      = "NY.GDP.MKTP.KD.ZG",
PIB_hab_croissance_pct       = "NY.GDP.PCAP.KD.ZG",
PIB_hab_USD_constant2015     = "NY.GDP.PCAP.KD",
Rente_ress_naturelles_pctPIB = "NY.GDP.TOTL.RT.ZS",
IDE_net_entrant_pctPIB       = "BX.KLT.DINV.WD.GD.ZS",
Ouverture_commerciale_pctPIB = "NE.TRD.GNFS.ZS",
Inflation_IPC_pct            = "FP.CPI.TOTL.ZG",
Depenses_publiques_pctPIB    = "NE.CON.GOVT.ZS",
FBCF_pctPIB                  = "NE.GDI.FTOT.ZS"
)
# ,
# Controle_corruption_WGI      = "CC.EST",
# Etat_droit_WGI               = "RL.EST",
# Efficacite_gouv_WGI          = "GE.EST"
# --- 2. Telechargement des donnees --------------------------------------------
donnees <- WDI(
country   = pays_iso2,
indicator = indicateurs,
start     = 1995,
end       = 2024,
extra     = TRUE   # ajoute notamment iso3c, region, income
)
# --- 3. Mise en forme (format "long" pays x annee) -----------------------------
panel_macro <- donnees %>%
rename(Code_ISO3 = iso3c, Pays = country, Annee = year) %>%
select(Code_ISO3, Pays, Annee, all_of(names(indicateurs))) %>%
arrange(Code_ISO3, Annee)
# Verification rapide : nombre de lignes attendu = 8 pays x 30 annees = 240
cat("Nombre de lignes :", nrow(panel_macro), "(attendu : 240)\n")
cat("Apercu :\n")
print(head(panel_macro, 10))
# --- 4. Export -------------------------------------------------------------------
write.csv(panel_macro, "donnees_macro_UEMOA.csv", row.names = FALSE)
write.xlsx(panel_macro, "donnees_macro_UEMOA.xlsx")
# --- 5. (Optionnel) fusion avec le panel ITIE existant ----------------------------
# Si le fichier panel_ITIE_UEMOA.xlsx (onglet "Panel_Data") est dans le meme
# dossier, decommenter les lignes suivantes pour produire un panel complet :
#
# panel_itie  <- read.xlsx("panel_ITIE_UEMOA.xlsx", sheet = "Panel_Data")
# panel_itie  <- panel_itie %>% select(-all_of(names(indicateurs)))  # retire colonnes vides
# panel_final <- left_join(panel_itie, panel_macro %>% select(-Pays),
#                           by = c("Code_ISO3", "Annee"))
# write.xlsx(panel_final, "panel_ITIE_UEMOA_complet.xlsx")
# --- Note sur les indicateurs WGI -------------------------------------------------
# Les variables Controle_corruption_WGI, Etat_droit_WGI et Efficacite_gouv_WGI
# (source : Worldwide Governance Indicators) ne sont disponibles qu'en 1996,
# 1998, 2000, puis chaque annee depuis 2002. Les annees 1995, 1997, 1999 et
# 2001 apparaitront avec des valeurs NA : c'est attendu, pas une erreur de
# telechargement.
# ==============================================================================
# 6. Construction de la variable de traitement ITIE
#    (dummy, score ordinal, statut), pour produire un panel complet sans avoir
#    a ouvrir le fichier panel_ITIE_UEMOA.xlsx.
#
#    Le codage reproduit celui de l'onglet Panel_Data, fonde sur l'historique
#    documente de l'ITIE (eiti.org). Les statuts du Mali, du Burkina Faso, du
#    Niger (post-2023) et du Senegal restent a verifier/affiner - voir l'onglet
#    "Guide_Collecte_Donnees" du classeur.
# ==============================================================================
construire_itie <- function(code, annee) {
if (code %in% c("BEN", "GNB")) {
return(c(membre_jamais = 0, dummy = 0, score = 0,
statut = "Non-membre ITIE"))
}
if (code == "NER") {
if (annee < 2007)
return(c(membre_jamais = 1, dummy = 0, score = 0,
statut = "Non-membre (avant adhesion)"))
if (annee >= 2007 & annee <= 2010)
return(c(membre_jamais = 1, dummy = 1, score = 1,
statut = "Candidat EITI (adhesion 2007)"))
if (annee >= 2011 & annee <= 2017)
return(c(membre_jamais = 1, dummy = 1, score = 2,
statut = "Conforme (EITI Compliant depuis mars 2011), retrait en oct. 2017"))
if (annee >= 2018 & annee <= 2019)
return(c(membre_jamais = 1, dummy = 0, score = 0,
statut = "Hors ITIE (retrait depuis oct. 2017)"))
return(c(membre_jamais = 1, dummy = 1, score = 1,
statut = "Reintegration en 2020 (candidat) ; Validation perturbee par le coup d'Etat de 2023"))
}
if (code == "MLI") {
if (annee < 2006)
return(c(membre_jamais = 1, dummy = 0, score = 0,
statut = "Non-membre (avant adhesion)"))
if (annee >= 2006 & annee <= 2010)
return(c(membre_jamais = 1, dummy = 1, score = 1,
statut = "Candidat EITI"))
return(c(membre_jamais = 1, dummy = 1, score = 2,
statut = "Conforme depuis 2011 (statut post-2021 a verifier)"))
}
if (code == "CIV") {
if (annee < 2008)
return(c(membre_jamais = 1, dummy = 0, score = 0,
statut = "Non-membre (avant adhesion)"))
if (annee >= 2008 & annee <= 2012)
return(c(membre_jamais = 1, dummy = 1, score = 1,
statut = "Candidat EITI"))
return(c(membre_jamais = 1, dummy = 1, score = 2,
statut = "Conforme depuis 2013"))
}
if (code == "BFA") {
if (annee < 2008)
return(c(membre_jamais = 1, dummy = 0, score = 0,
statut = "Non-membre (avant adhesion)"))
if (annee >= 2008 & annee <= 2012)
return(c(membre_jamais = 1, dummy = 1, score = 1,
statut = "Candidat EITI"))
return(c(membre_jamais = 1, dummy = 1, score = 2,
statut = "Conforme depuis 2013 (statut post-2022 a verifier)"))
}
if (code == "TGO") {
if (annee < 2010)
return(c(membre_jamais = 1, dummy = 0, score = 0,
statut = "Non-membre (avant adhesion)"))
if (annee >= 2010 & annee <= 2012)
return(c(membre_jamais = 1, dummy = 1, score = 1,
statut = "Candidat EITI"))
return(c(membre_jamais = 1, dummy = 1, score = 2,
statut = "Conforme depuis 2013"))
}
if (code == "SEN") {
if (annee < 2013)
return(c(membre_jamais = 1, dummy = 0, score = 0,
statut = "Non-membre (avant adhesion)"))
if (annee >= 2013 & annee <= 2017)
return(c(membre_jamais = 1, dummy = 1, score = 1,
statut = "Candidat EITI (adhesion 2013)"))
return(c(membre_jamais = 1, dummy = 1, score = 2,
statut = "Validation engagee (issue precise a confirmer)"))
}
stop("Code pays inconnu : ", code)
}
# Application ligne par ligne et ajout des 4 colonnes ITIE
itie_mat <- t(mapply(construire_itie, panel_macro$Code_ISO3, panel_macro$Annee))
panel_final <- panel_macro %>%
mutate(
ITIE_membre_jamais = as.numeric(itie_mat[, "membre_jamais"]),
ITIE_dummy         = as.numeric(itie_mat[, "dummy"]),
ITIE_score_ordinal = as.numeric(itie_mat[, "score"]),
ITIE_statut        = itie_mat[, "statut"]
)
write.xlsx(panel_final, "panel_ITIE_UEMOA_complet.xlsx")
cat("Panel complet ecrit dans panel_ITIE_UEMOA_complet.xlsx -",
nrow(panel_final), "lignes,", ncol(panel_final), "colonnes\n")
