# # Suppose une adoption "absorbante" : a utiliser de preference sur le sous-
# # echantillon EXCLUANT le Niger (traitement non absorbant), ou en traitant le
# # Niger comme un cas particulier discute separement dans le memoire.
# library(did)
#
